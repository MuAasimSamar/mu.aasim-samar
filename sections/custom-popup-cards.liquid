<style>
    section.custom-popup-cards {
    margin: 90px 0 50px;
    }
    .custom-popup-cards h2 {
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0;
    font-weight: 400;
    color: #000;
    margin: 0 0 30px;
    }
  /* Grid & Hotspots */
  .cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .card { position: relative; line-height: 0; }
  .card-img { width: 100%; height: auto; }
  .open-popup {
    position: absolute;border: none;
    background: transparent; cursor: pointer;
    z-index: 2; display: flex; align-items: center; justify-content: center;
  }

  /* Overlay */
  .popup-overlay {
    display: none; position: fixed; inset: 0; 
    background: rgba(0,0,0,0.6); z-index: 999;
    align-items: center; justify-content: center;
  }
  .popup-overlay.active { display: flex; }

  /* Content Layout */
  .popup-content { background: #fff; padding: 37px 16px 20px 16px; max-width: 320px; width: 90%; position: relative; }
  .popup-inner .first-part { display: flex; gap: 20px; }
  .popup-left img { width: 120px; height: 140px; object-fit: cover; display: block; }
  h2#popup-title {
    font-size: 16px;
    line-height: 120%;
    font-weight: 300;
    letter-spacing: 0;
    margin: 0 0 20px;
    color: #000;
    text-align: left;
  }  
  p#popup-price {
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0;
    font-weight: 600;
    color: #000;
    margin: 0 0 12px;
  }
  div#popup-description p {
    margin: 0;
    line-height: 110%;
    letter-spacing: -1%;
    font-weight: 400;
    color: #000;
    font-size: 14px;
  }
  div#popup-options {
    display: flex;
    flex-direction: column-reverse;
    margin-top: 8px;
    gap: 12px;
  }
  
  /* Inputs */
  .option-group { margin-bottom: 10px; }
  .option-label { font-size: 14px; font-weight: 400; display: block; margin-bottom: 6px; }
  .color-tabs-container { display: flex;  flex-wrap: wrap; }
  .color-tab { border: 0.5px solid #333; width: 50%; padding: 5px 10px; cursor: pointer; font-size: 18px; color: #000; font-weight: 400; position: relative; }
  .color-tab.selected { border-color: #000; background: #eee; }
  .color-swatch { width: 6px; position: absolute; left: 0; top: 0; bottom: 0; border-right: 0.5px solid #333; }
  
  .custom-dropdown { position: relative; border: 0.5px solid #000; padding: 8px; font-size: 16px; color: #000000; cursor: pointer; position: relative; }
  .dropdown-options { 
    position: absolute; top: 100%; left: -1px; right: -1px; 
    background: #fff; border: 1px solid #ccc; display: none; z-index: 5;
  }
  .custom-dropdown::after {
  content: "▼"; 
  position: absolute;
  right: 8px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 18px;
  pointer-events: none;
}
.custom-dropdown::before {
  content: ""; 
  position: absolute;
  right: 13%;
  top: 0;
  width: 1px;
  height: 100%;
  background: #000;
}
  .custom-dropdown.open .dropdown-options { display: block; }
  .dropdown-option { padding: 8px; border-bottom: 1px solid #eee; }

  #add-to-cart { background: #000; font-size: 16px; text-transform: uppercase; color: #fff; border: none; width: 100%; padding: 14px; cursor: pointer; margin-top: 50px; display: flex; align-items: center; justify-content: center; gap: 20px; }
  .close-popup { position: absolute; top: 5px; right: 10px; font-size: 24px; cursor: pointer; border: none; background: none; }

  @media (max-width: 768px) { 
    .popup-inner { flex-direction: column; } 
    .popup-left, .popup-right { width: 100%; } 
    section.custom-popup-cards {
    margin: 40px 0 24px;
    }
    .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    }
    .custom-popup-cards h2 {
    font-size: 24px;
    margin: 0 0 20px;
    text-align: center;
    }
    div#popup-description p {
    margin: 0;
    line-height: 110%;
    letter-spacing: -1%;
    font-weight: 400;
    color: #000;
    font-size: 12px;
    }
    }
</style>

<section class="custom-popup-cards">
  <div class="page-width">
  <h2>{{ section.settings.title }}</h2>
    <div class="cards-grid">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}
        <div class="card" data-product="{{ product | json | escape }}">
          <img src="{{ block.settings.image | image_url: width: 600 }}" class="card-img" alt="look">
          <button class="open-popup" style="top:{{block.settings.vertical_pos}}%; left:{{block.settings.horizontal_pos}}%; transform:translate(-50%,-50%);">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="11" fill="#F8F8F8" fill-opacity="0.9"/>
            <path d="M11.3457 7.04175V15.5033" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
            <path d="M7.11523 11.2725H15.5768" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="popup-overlay" id="popup">
    <div class="popup-content">
      <button class="close-popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none">
<path d="M4.24219 4.24279L12.7275 12.7281" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
<path d="M4.24219 12.7278L12.7275 4.24249" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
</svg>
      </button>
      <div class="popup-inner">
        <div class="first-part">
        <div class="popup-left"><img id="popup-image" src=""></div>
        <div class="popup-right">
          <h2 id="popup-title"></h2>
          <p id="popup-price"></p>
          <div id="popup-description"></div>
        </div>
        </div>
          <div id="popup-options"></div>
          <button id="add-to-cart">Add to Cart
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="12" viewBox="0 0 36 12" fill="none">
            <path d="M0.75 4.77295L9.20657e-08 4.77295L-9.20657e-08 6.27295L0.75 6.27295L0.75 4.77295ZM34.9798 6.05328C35.2727 5.76039 35.2727 5.28551 34.9798 4.99262L30.2068 0.21965C29.9139 -0.0732432 29.4391 -0.0732433 29.1462 0.21965C28.8533 0.512544 28.8533 0.987417 29.1462 1.28031L33.3888 5.52295L29.1462 9.76559C28.8533 10.0585 28.8533 10.5334 29.1462 10.8263C29.4391 11.1191 29.9139 11.1191 30.2068 10.8263L34.9798 6.05328ZM0.75 6.27295L34.4495 6.27295L34.4495 4.77295L0.75 4.77295L0.75 6.27295Z" fill="white"/>
            </svg> 
          </button>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const popup = document.getElementById('popup');
  const optionsWrap = document.getElementById('popup-options');
  const btn = document.getElementById('add-to-cart');
  let currentProd = null;
  let currentVarId = null;

  // find variant based on UI selection
  const findVariant = () => {
    const chosen = [];
    optionsWrap.querySelectorAll('.option-group').forEach(g => {
      const tab = g.querySelector('.color-tab.selected');
      const drop = g.querySelector('.custom-dropdown span');
      if (tab) chosen.push(tab.dataset.value);
      else if (drop) chosen.push(drop.textContent.trim());
    });
    return currentProd.variants.find(v => chosen.every((val, i) => v['option' + (i + 1)] === val));
  };

  const updateUI = () => {
    const v = findVariant();
    if (v) {
      currentVarId = v.id;
      document.getElementById('popup-price').innerText = `$ ${(v.price/100).toFixed(2)}`;
      btn.disabled = !v.available;
      {% comment %} btn.innerText = v.available ? 'Add to Cart →' : 'Sold Out'; {% endcomment %}
    } else {
      currentVarId = null;
      btn.disabled = true;
      btn.innerText = 'Unavailable';
    }
  };

  // build selectors
  const buildUI = (p) => {
    optionsWrap.innerHTML = '';
    p.options.forEach((opt, idx) => {
      const vals = [...new Set(p.variants.map(v => v['option'+(idx+1)]))];
      const group = document.createElement('div');
      group.className = 'option-group';
      group.innerHTML = `<label class="option-label">${opt}</label>`;

      if (opt.toLowerCase().includes('color')) {
        const div = document.createElement('div');
        div.className = 'color-tabs-container';
        vals.forEach((v, i) => {
          const tab = document.createElement('div');
          tab.className = `color-tab ${i===0?'selected':''}`;
          tab.dataset.value = v;
          tab.innerHTML = `<span class="color-swatch" style="background:${v.replace(/\s/g,'')}"></span>${v}`;
          tab.onclick = () => { div.querySelectorAll('.color-tab').forEach(t=>t.classList.remove('selected')); tab.classList.add('selected'); updateUI(); };
          div.appendChild(tab);
        });
        group.appendChild(div);
      } else {
        const drop = document.createElement('div');
        drop.className = 'custom-dropdown';
        drop.innerHTML = `<span>${vals[0]}</span><div class="dropdown-options">${vals.map(v=>`<div class="dropdown-option">${v}</div>`).join('')}</div>`;
        drop.onclick = (e) => {
          drop.classList.toggle('open');
          if (e.target.classList.contains('dropdown-option')) {
            drop.querySelector('span').innerText = e.target.innerText;
            updateUI();
          }
        };
        group.appendChild(drop);
      }
      optionsWrap.appendChild(group);
    });
  };

  // events
  document.querySelectorAll('.open-popup').forEach(b => {
    b.onclick = () => {
      currentProd = JSON.parse(b.closest('.card').dataset.product);
      document.getElementById('popup-title').innerText = currentProd.title;
      document.getElementById('popup-image').src = currentProd.featured_image;
      document.getElementById('popup-description').innerHTML = currentProd.description;
      buildUI(currentProd);
      updateUI();
      popup.classList.add('active');
    };
  });

  document.querySelector('.close-popup').onclick = () => popup.classList.remove('active');

  btn.onclick = () => {
    if(!currentVarId) return;
    btn.innerText = 'Adding...';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ id: currentVarId, quantity: 1 })
    }).then(() => {
        popup.classList.remove('active');   
        btn.innerText = 'Add to Cart';      
        btn.disabled = false;               

        currentVarId = null;
        currentProd = null;
        window.location.href = '/cart';
    }); // simple reload for cart update
  };
});
</script>

{% schema %}
{
  "name": "Popup Product Cards",
    "settings": [
    {
    "type":"text",
    "id":"title",
    "label":"Title",
    "default":"Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "vertical_pos", "min": 0, "max": 100, "default": 50, "unit": "%", "label": "Vertical" },
        { "type": "range", "id": "horizontal_pos", "min": 0, "max": 100, "default": 50, "unit": "%", "label": "Horizontal" }
      ]
    }
  ],
  "presets": [{ "name": "Popup Product Cards" }]
}
{% endschema %}